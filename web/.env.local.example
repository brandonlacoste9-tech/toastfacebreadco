# ═══════════════════════════════════════════════════════════════
# JustBookMe — APP CREDENTIALS (copy → web/.env.local)
# Never commit .env.local. Rotate any secret shared in chat.
# ═══════════════════════════════════════════════════════════════
#
# CHECK STATUS:  npm run check:env
# PUSH NETLIFY:  node ../scripts/push-netlify-env-cli.mjs
#
# ── USE THESE (what the app reads) ─────────────────────────────
#   Supabase     NEXT_PUBLIC_SUPABASE_URL, ANON_KEY, SERVICE_ROLE_KEY
#   Site         NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_CONTACT_EMAIL
#   Twilio SMS   TWILIO_ACCOUNT_SID (AC…), TWILIO_AUTH_TOKEN, TWILIO_PHONE_NUMBER (+1…)
#   Calendly     NEXT_PUBLIC_CALENDLY_URL (optional)
#   Ollama       OLLAMA_BASE_URL, OLLAMA_MODEL (local dev only)
#   Stripe       STRIPE_SECRET_KEY + 6 price IDs + webhook secret
#
# ── DO NOT USE (wrong type — ignore for this app) ──────────────
#   US…          User SID
#   OQ… + secret OAuth App Client ID/Secret (user login, not SMS API)
#   SK… + secret API Key (optional; Auth Token is simpler and works)
#
# ═══════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL (REQUIRED) ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://justbookme.ca
NEXT_PUBLIC_CONTACT_EMAIL=info@justbookme.ca

# ── Twilio SMS (need all 3 to send) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15145550100
# TWILIO_PHONE_NUMBER_SID=PNxxxxxxxx   # optional — Twilio resource ID for voice webhooks
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx   # optional instead of phone

# ── Direct Postgres (local migrations only — NOT Netlify) ───────
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ── Cron (optional — appointment reminder SMS) ───────────────────
# CRON_SECRET=generate-a-long-random-string
# Hit: GET https://justbookme.ca/api/cron/reminders with Authorization: Bearer <CRON_SECRET>

# ── Demo booking (optional) ─────────────────────────────────────
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link/15min

# ── Ollama / Gemma4 (local dev only) ────────────────────────────
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gemma4

# ── Vapi (AI voice — Phase 2) ─────────────────────────────────────
# Dashboard → API Keys. Private = server only. Public = web widget.
# VAPI_PRIVATE_KEY=
# NEXT_PUBLIC_VAPI_PUBLIC_KEY=
# VAPI_ASSISTANT_ID=          # set by: npm run vapi:provision
# VAPI_DEFAULT_BUSINESS_ID=   # pilot business UUID (matches phone_number)
# VAPI_WEBHOOK_SECRET=        # optional — x-vapi-secret header
# VAPI_TRANSFER_NUMBER=       # optional — human transfer destination

# ── Stripe (billing) ────────────────────────────────────────────
# Dashboard → Developers → API keys (test mode first)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from Dashboard → Webhooks or: npm run stripe:setup
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_PREMIUM_MONTHLY=price_...
# STRIPE_PRICE_PREMIUM_ANNUAL=price_...
# Setup: npm run stripe:setup